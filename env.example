## Database
# PostgreSQL connection string. Example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/banco?schema=public"
DATABASE_URL=""

## LLM
# Used by /api/generate
# Select provider: "gemini" or "ollama"
LLM_PROVIDER_TYPE="gemini"

## Gemini
#...LLM_PROVIDER_TYPE="gemini"
GEMINI_API_KEY=""
# Examples (GEMINI_MODEL): "gemini-2.5-flash-lite", "gemini-2.5-flash"
GEMINI_MODEL="gemini-2.5-flash-lite"
# Model used for image understanding during file upload
GEMINI_VISION_MODEL="gemini-2.5-flash"

## Ollama (example)
# ...LLM_PROVIDER_TYPE="ollama"
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="gemini-3-flash-preview:cloud"

## Google Cloud Storage (for Data Node file uploads)
GCS_BUCKET_NAME=""
GCS_UPLOAD_PREFIX="data-core"
