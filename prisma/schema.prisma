generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Clerk user ID for authentication
  clerkUserId   String   @unique

  // Relations
  maps          Map[]
  subscription  Subscription?
  usageRecords  UsageRecord[]
  uploadedFiles UploadedFile[]
}

model Map {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String

  nodes     Node[]
  edges     Edge[]
}

model Node {
  id         String   @id // React Flow node id (stable client-side)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  mapId      String
  map        Map      @relation(fields: [mapId], references: [id], onDelete: Cascade)

  type       String?
  positionX  Float
  positionY  Float
  data       Json

  generated  GeneratedContent[]
  fileLinks  NodeFileLink[]

  @@index([mapId])
}

model Edge {
  id         String   @id // React Flow edge id (stable client-side)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  mapId      String
  map        Map      @relation(fields: [mapId], references: [id], onDelete: Cascade)

  source     String
  target     String
  type       String?
  data       Json?

  @@index([mapId])
  @@index([source])
  @@index([target])
}

model GeneratedContent {
  id           String       @id @default(cuid())
  createdAt    DateTime     @default(now())

  nodeId       String
  node         Node         @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  platform     String
  model        String
  prompt       String
  output       String

  // Determinism / regeneration tracking
  temperature  Float?
  seed         Int?
  revision     Int          @default(1)

  // Usage tracking
  usageRecord  UsageRecord?

  @@index([nodeId, platform])
}

enum SubscriptionTier {
  FREE
  CREATOR
  PRO
}

model Subscription {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  tier         SubscriptionTier
  isActive     Boolean  @default(true)
  startDate    DateTime @default(now())
  endDate      DateTime?
  
  usageLimit   Int      // Weekly generation limit
  mapLimit     Int      @default(10) // Total number of maps allowed
  resetPeriod  String   @default("week") // "week" or "month"
}

model UsageRecord {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  generationId String   @unique
  generatedContent GeneratedContent @relation(fields: [generationId], references: [id], onDelete: Cascade)
  
  usageDate    DateTime @default(now())
  
  @@index([userId, usageDate])
  @@index([userId, createdAt])
}

model UploadedFile {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  originalName  String
  extension     String
  mimeType      String
  sizeBytes     BigInt
  gcsBucket     String
  gcsObjectPath String   @unique

  nodeLinks     NodeFileLink[]

  @@index([userId, createdAt])
}

model NodeFileLink {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  nodeId    String
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  fileId    String
  file      UploadedFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([nodeId, fileId])
  @@index([fileId])
}

